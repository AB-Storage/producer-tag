{
  "name": "producer-tag",
  "version": "1.0.0",
  "description": "Play your signature \"producer tag\" sound every time you commit or push to git. Record a library of tags, autotune them, and pick which one drops.",
  "bin": {
    "producer-tag": "server.js"
  },
  "scripts": {
    "start": "node server.js",
    "app": "node gui.js",
    "install-hooks": "bash install.sh"
  },
  "keywords": [
    "git",
    "git-hooks",
    "audio",
    "producer-tag",
    "afplay",
    "autotune",
    "ffmpeg",
    "developer-fun"
  ],
  "author": "unemployedarvin",
  "license": "MIT",
  "engines": {
    "node": ">=14"
  },
  "files": [
    "server.js",
    "gui.js",
    "public/",
    "hooks/",
    "install.sh",
    "Producer Tag.app/",
    "Producer Tag.bat",
    "icon.png",
    "CLAUDE.md",
    "AGENTS.md"
  ]
}
