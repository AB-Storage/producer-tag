#!/bin/bash
# Producer Tag — macOS double-click launcher. Opens the control-panel window;
# closing the window quits. The git hooks keep working regardless.
DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$DIR" || exit 1

# Find node (a double-clicked app does not inherit your shell PATH).
NODE="$(command -v node 2>/dev/null)"
if [ -z "$NODE" ]; then
  for p in /opt/homebrew/bin/node /usr/local/bin/node /usr/bin/node "$HOME"/.local/*/bin/node "$HOME"/.nvm/versions/node/*/bin/node; do
    [ -x "$p" ] && NODE="$p" && break
  done
fi
if [ -z "$NODE" ]; then
  osascript -e 'display alert "Producer Tag" message "Node.js is required. Install it from https://nodejs.org and try again."'
  exit 1
fi

exec "$NODE" gui.js
